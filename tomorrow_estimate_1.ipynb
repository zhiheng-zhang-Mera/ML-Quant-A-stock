# ==============================================
# 获取最近三个月的ETF历史数据
# ==============================================
def fetch_etf_data(symbol):
    end_date = datetime.today().strftime("%Y%m%d")
    start_date = (datetime.today() - timedelta(days=90)).strftime("%Y%m%d")

    etf_df = ak.fund_etf_hist_em(symbol=symbol,
                                 period="daily",
                                 start_date=start_date,
                                 end_date=end_date,
                                 adjust="")
    
    print("原始ETF数据列名如下：")  # 调试信息
    print(etf_df.columns.tolist())  # 查看真实列名
    
    # 根据实际列名修改下面的映射
    column_mapping = {
        "日期": "日期",
        "开盘": "开盘",
        "最高": "最高",
        "最低": "最低",
        "收盘": "收盘",
        "成交量": "成交量"
    }

    selected_columns = {k: v for k, v in column_mapping.items() if k in etf_df.columns}
    etf_df = etf_df[selected_columns.keys()].rename(columns=selected_columns)

    etf_df['日期'] = pd.to_datetime(etf_df['日期'])
    return etf_df.sort_values('日期').reset_index(drop=True)

# ==============================================
# 特征工程函数
# ==============================================
def prepare_features(df):
    df = df.copy()
    df['日期'] = pd.to_datetime(df['日期'])
    df.set_index('日期', inplace=True)

    # 添加滞后特征
    for lag in range(1, 6):
        df[f'收盘_滞后{lag}'] = df['收盘'].shift(lag)
        df[f'最高_滞后{lag}'] = df['最高'].shift(lag)
        df[f'最低_滞后{lag}'] = df['最低'].shift(lag)

    # 技术指标
    df['SMA_5'] = df['收盘'].rolling(window=5).mean()
    df['Volatility'] = df['最高'] - df['最低']

    df.dropna(inplace=True)

    # 特征列
    feature_cols = [col for col in df.columns if col not in ['收盘', '最高', '最低']]
    X = df[feature_cols]
    y_high = df['最高']
    y_low = df['最低']

    return X, y_high, y_low


# ==============================================
# 构建 LSTM 模型
# ==============================================
def build_lstm(input_shape):
    model = Sequential()
    model.add(LSTM(64, input_shape=input_shape, return_sequences=True))
    model.add(Dropout(0.2))  # Dropout 层用于蒙特卡洛方法
    model.add(LSTM(32))
    model.add(Dropout(0.2))
    model.add(Dense(1))
    model.compile(optimizer=Adam(learning_rate=0.001), loss='mse')
    return model


# ==============================================
# 模型训练函数
# ==============================================
def train_models(X, y_high, y_low):
    models_high = {}
    models_low = {}

    # Linear Regression
    model = LinearRegression()
    model.fit(X, y_high)
    scaler = StandardScaler().fit(X)
    models_high['LinearRegression'] = (model, scaler)

    model = LinearRegression()
    model.fit(X, y_low)
    scaler = StandardScaler().fit(X)
    models_low['LinearRegression'] = (model, scaler)

    # Random Forest
    model = RandomForestRegressor(n_estimators=100, random_state=42)
    model.fit(X, y_high)
    scaler = StandardScaler().fit(X)
    models_high['RandomForest'] = (model, scaler)

    model = RandomForestRegressor(n_estimators=100, random_state=42)
    model.fit(X, y_low)
    scaler = StandardScaler().fit(X)
    models_low['RandomForest'] = (model, scaler)

    # LightGBM
    model = lgb.LGBMRegressor(n_estimators=100)
    model.fit(X, y_high)
    scaler = StandardScaler().fit(X)
    models_high['LightGBM'] = (model, scaler)

    model = lgb.LGBMRegressor(n_estimators=100)
    model.fit(X, y_low)
    scaler = StandardScaler().fit(X)
    models_low['LightGBM'] = (model, scaler)

    # XGBoost
    model = xgb.XGBRegressor(n_estimators=100, use_label_encoder=False)
    model.fit(X, y_high)
    scaler = StandardScaler().fit(X)
    models_high['XGBoost'] = (model, scaler)

    model = xgb.XGBRegressor(n_estimators=100, use_label_encoder=False)
    model.fit(X, y_low)
    scaler = StandardScaler().fit(X)
    models_low['XGBoost'] = (model, scaler)

    # LSTM
    def reshape_for_lstm(data):
        return data.values.reshape((data.shape[0], data.shape[1], 1))

    X_lstm = reshape_for_lstm(X)

    model = build_lstm((X.shape[1], 1))
    model.fit(X_lstm, y_high.values, epochs=10, batch_size=16, verbose=0)
    models_high['LSTM'] = (model, StandardScaler().fit(X))

    model = build_lstm((X.shape[1], 1))
    model.fit(X_lstm, y_low.values, epochs=10, batch_size=16, verbose=0)
    models_low['LSTM'] = (model, StandardScaler().fit(X))

    return models_high, models_low


# ==============================================
# 预测函数（含蒙特卡洛置信区间）
# ==============================================
def predict_future(models_high, models_low, last_row, mc_samples=100):
    high_preds = {name: [] for name in models_high}
    low_preds = {name: [] for name in models_low}

    # 高价预测（蒙特卡洛方法）
    for name, (model, scaler) in models_high.items():
        scaled_data = scaler.transform([last_row])
        if name == 'LSTM':
            for _ in range(mc_samples):
                pred = model.predict(scaled_data.reshape(1, -1, 1))[0][0]
                high_preds[name].append(pred)
        else:
            for _ in range(mc_samples):
                pred = model.predict(scaled_data)[0]
                high_preds[name].append(pred)

    # 低价预测（蒙特卡洛方法）
    for name, (model, scaler) in models_low.items():
        scaled_data = scaler.transform([last_row])
        if name == 'LSTM':
            for _ in range(mc_samples):
                pred = model.predict(scaled_data.reshape(1, -1, 1))[0][0]
                low_preds[name].append(pred)
        else:
            for _ in range(mc_samples):
                pred = model.predict(scaled_data)[0]
                low_preds[name].append(pred)

    # 收集结果
    result = []

    all_high_mean = []
    all_low_mean = []

    print("\n各模型预测值与置信区间：")
    for name in models_high.keys():
        h_preds = high_preds[name]
        l_preds = low_preds[name]

        h_avg = np.mean(h_preds)
        h_upper = np.percentile(h_preds, 97.5)
        h_lower = np.percentile(h_preds, 2.5)

        l_avg = np.mean(l_preds)
        l_upper = np.percentile(l_preds, 97.5)
        l_lower = np.percentile(l_preds, 2.5)

        result.append({
            '模型': name,
            '预测最高价': h_avg,
            '上界': h_upper,
            '下界': h_lower,
            '预测最低价': l_avg,
            '下界': l_lower,
            '上界': l_upper
        })

        all_high_mean.append(h_avg)
        all_low_mean.append(l_avg)

        print(f"{name}:")
        print(f"  最高价预测: {h_avg:.6f} | 置信区间: [{h_lower:.6f}, {h_upper:.6f}]")
        print(f"  最低价预测: {l_avg:.6f} | 置信区间: [{l_lower:.6f}, {l_upper:.6f}]\n")

    # 输出平均值
    avg_high = np.mean(all_high_mean)
    avg_low = np.mean(all_low_mean)
    print("【平均预测值】")
    print(f"  最高价: {avg_high:.6f}")
    print(f"  最低价: {avg_low:.6f}")

    return pd.DataFrame(result)


# ==============================================
# 主函数入口
# ==============================================
def main(symbol):
    # 示例：模拟读取ETF数据
    df = fetch_etf_data(symbol)

    # 特征工程
    X, y_high, y_low = prepare_features(df)

    # 训练模型
    models_high, models_low = train_models(X, y_high, y_low)

    # 获取最新样本
    last_row = X.iloc[-1].copy()

    # 预测明天的最高价和最低价
    predict_future(models_high, models_low, last_row, mc_samples=100)


if __name__ == "__main__":
    symbol = input("请输入ETF代码（例如：513500）：").strip()
    main(symbol)